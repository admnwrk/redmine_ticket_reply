<style>
  #tr-email-preview-panel { padding: 12px 16px; }
  .tr-email-preview-headers { border-bottom: 1px solid #ddd; padding-bottom: 8px; margin-bottom: 12px; }
  .tr-email-preview-headers p { margin: 2px 0; }
  .tr-email-preview-attachments { margin: 2px 0 4px 0; padding-left: 20px; }
  .tr-email-preview-body { padding: 4px 2px; }
</style>

<h2><%= l(:label_send_ticket_reply, default: 'Per E-Mail antworten') %> &ndash; #<%= @issue.id %> <%= h @issue.subject %></h2>

<%= form_tag(issue_ticket_reply_path(@issue), method: :post, multipart: true, id: 'tr-form') do %>
  <div class="box tabular" id="tr-form-fields">
    <% if @from_options.size > 1 %>
      <p>
        <label><%= l(:field_from, default: 'Von') %></label>
        <%= select_tag 'from_mode', options_for_select(@from_options, @from_mode), id: 'from_mode' %>
        <em class="info" id="from-preview"><%= @from_preview[@from_mode] %></em>
      </p>
    <% else %>
      <%= hidden_field_tag 'from_mode', @from_mode %>
    <% end %>
    <p>
      <label><%= l(:field_mail_to, default: 'An') %> <span class="required">*</span></label>
      <%= text_field_tag 'to', @to, size: 70 %>
      <em class="info">Mehrere Adressen mit Komma oder Semikolon trennen.</em>
    </p>
    <p>
      <label>CC</label>
      <%= text_field_tag 'cc', @cc, size: 70, id: 'cc' %>
      <% if @system_mailbox_address.present? %>
        <em class="info" id="cc-hint" style="display:none;"><%= l(:text_cc_system_mailbox, default: 'Das System-Postfach wird bei &bdquo;Eigene Adresse&ldquo; automatisch ergaenzt.') %></em>
      <% end %>
    </p>
    <p>
      <label>BCC</label>
      <%= text_field_tag 'bcc', @bcc, size: 70 %>
    </p>
    <p>
      <label><%= l(:field_template, default: 'Vorlage') %></label>
      <%= select_tag 'template',
            options_for_select(
              [[l(:label_external, default: 'Extern (Kunde)'), 'external'],
               [l(:label_internal, default: 'Intern'), 'internal']],
              @template) %>
      <em class="info"><%= l(:text_template_auto, default: 'Vorauswahl anhand der Empfaengerdomaene.') %></em>
    </p>

    <% if @canned.any? %>
      <p>
        <label><%= l(:field_canned, default: 'Textbaustein') %></label>
        <%= select_tag 'canned_select',
              options_for_select([[l(:label_choose_canned, default: '— Baustein einfuegen —'), '']] +
                                 @canned.map { |c| [c[:label], c[:label]] }) %>
        <em class="info">Fuellt Betreff/Text. Danach frei editierbar.</em>
      </p>
    <% end %>

    <p>
      <label><%= l(:field_subject, default: 'Betreff') %></label>
      <%= text_field_tag 'subject', @subject, size: 70 %>
      <em class="info">Den Teil <strong>[&hellip; #<%= @issue.id %>]</strong> bitte stehen lassen &ndash; daran wird die Antwort dem Ticket zugeordnet.</em>
    </p>

    <p>
      <label><%= l(:field_notes, default: 'Text') %> <span class="required">*</span></label>
      <span class="tr-editor" style="display:block;width:95%;">
        <%= text_area_tag 'body', @body, rows: 14, id: 'body', class: 'wiki-edit', style: 'width:100%;min-height:22em;resize:vertical;box-sizing:border-box;' %>
        <%= wikitoolbar_for 'body' %>
      </span>
    </p>

    <p>
      <label><%= l(:field_include_history, default: 'Verlauf') %></label>
      <label class="block">
        <%= check_box_tag 'include_history', '1', false %>
        <%= l(:text_include_history, default: 'Bisherigen Ticket-Verlauf als Textdatei anhaengen (ohne private Notizen)') %>
      </label>
    </p>

    <p>
      <label><%= l(:field_close_ticket, default: 'Abschluss') %></label>
      <label class="block">
        <%= check_box_tag 'close_ticket', '1', false %>
        <%= l(:text_close_ticket, default: 'Ticket nach dem Senden schliessen') %>
      </label>
    </p>

    <p>
      <label><%= l(:field_uploads, default: 'Neue Anhaenge') %></label>
      <%= file_field_tag 'uploads[]', multiple: true %>
      <em class="info"><%= l(:text_uploads_info, default: 'Dateien werden nur der E-Mail angehaengt, nicht dem Ticket.') %></em>
    </p>

    <% if @issue.attachments.any? %>
      <p>
        <label><%= l(:label_attachment_plural, default: 'Anhaenge') %></label>
        <span>
          <% @issue.attachments.each do |a| %>
            <label class="block">
              <%= check_box_tag 'attachment_ids[]', a.id, false %>
              <%= h a.filename %> (<%= number_to_human_size(a.filesize) %>)
            </label>
          <% end %>
        </span>
      </p>
    <% end %>
  </div>

  <p id="tr-form-actions">
    <input type="button" value="<%= l(:button_preview_email, default: 'Vorschau') %>" onclick="trShowEmailPreview();" />
    &nbsp;
    <%= submit_tag l(:button_send, default: 'Senden') %>
    &nbsp;
    <%= link_to l(:button_cancel), issue_path(@issue) %>
  </p>
<% end %>

<div id="tr-email-preview-panel" class="box" style="display:none;">
  <h3><%= l(:label_email_preview, default: 'E-Mail-Vorschau (Empfaengeransicht)') %></h3>
  <div id="tr-email-preview-content"></div>
  <p>
    <input type="button" value="<%= l(:button_continue_editing, default: 'Weiter bearbeiten') %>" onclick="trBackToEdit();" />
    &nbsp;
    <input type="button" value="<%= l(:button_send, default: 'Senden') %>" onclick="trSendFromPreview();" />
  </p>
</div>

<% if @issue.description.present? %>
  <div class="issue details" style="margin-bottom:1em;">
    <h3><%= l(:field_description) %></h3>
    <p style="margin-top:0;">
      <%= h(@issue.author ? @issue.author.name : 'Unbekannt') %>
      &ndash; <%= format_time(@issue.created_on) %>
    </p>
    <div class="wiki description">
      <%= textilizable(@issue, :description) %>
    </div>
  </div>
<% end %>

<% if @recent_journals.any? %>
  <div class="box">
    <h3><%= l(:label_recent_journals, default: 'Letzte Kommentare') %></h3>
    <% @recent_journals.each do |j| %>
      <div class="journal" style="margin-bottom:1em;">
        <h4 style="margin:0 0 4px 0;">
          <%= h(j.user ? j.user.name : 'Unbekannt') %>
          &ndash; <%= format_time(j.created_on) %>
          <% if j.private_notes? %>
            <span class="badge badge-private private"><%= l(:field_private_notes) %></span>
          <% end %>
        </h4>
        <div class="wiki" style="border:1px solid #ddd;border-radius:3px;padding:6px 8px;background:#fafafa;">
          <%= textilizable(j, :notes) %>
        </div>
      </div>
    <% end %>
  </div>
<% end %>

<script type="text/javascript">
  //<![CDATA[
  (function () {
    // --- Von-Vorschau ---
    var fromPreview = <%= raw(@from_preview.to_json.gsub('</', '<\/')) %>;
    var systemMailbox = <%= raw(@system_mailbox_address.to_s.to_json) %>;
    var fromSel  = document.getElementById('from_mode');
    var fromInfo = document.getElementById('from-preview');
    var ccField  = document.getElementById('cc');
    var ccHint   = document.getElementById('cc-hint');

    function ccAddresses() {
      return (ccField.value || '').split(/[,;]/).map(function (a) { return a.trim(); }).filter(Boolean);
    }

    function applyFromMode() {
      var mode = fromSel.value;
      if (fromInfo) { fromInfo.textContent = fromPreview[mode] || ''; }
      if (!ccField || !systemMailbox) { return; }
      var addrs = ccAddresses();
      var has = addrs.some(function (a) { return a.toLowerCase() === systemMailbox.toLowerCase(); });
      if (mode === 'user_address') {
        if (!has) { ccField.value = addrs.concat([systemMailbox]).join(', '); }
        if (ccHint) { ccHint.style.display = ''; }
      } else if (ccHint) {
        ccHint.style.display = 'none';
      }
    }

    if (fromSel) {
      fromSel.addEventListener('change', applyFromMode);
      applyFromMode();
    }

    // --- Textbausteine einfuegen ---
    <% if @canned.any? %>
    var cannedData = <%= raw(@canned.index_by { |c| c[:label] }
                                    .transform_values { |c| { subject: c[:subject], body: c[:body] } }
                                    .to_json.gsub('</', '<\/')) %>;
    var cannedSel = document.getElementById('canned_select');
    if (cannedSel) {
      cannedSel.addEventListener('change', function () {
        var c = cannedData[this.value];
        if (!c) { return; }
        var body = document.getElementById('body');
        var subj = document.getElementById('subject');
        if (body && c.body) { body.value = c.body; }
        if (subj && c.subject) { subj.value = c.subject; }
      });
    }
    <% end %>
  })();

  // --- Vollstaendige E-Mail-Vorschau (Kopfzeilen + Text, Platzhalter aufgeloest) ---
  function csrfToken() {
    var token = document.querySelector('meta[name=csrf-token]');
    return token ? token.getAttribute('content') : '';
  }

  function trShowEmailPreview() {
    var form = document.getElementById('tr-form');
    var params = new URLSearchParams();
    ['to', 'cc', 'bcc', 'subject', 'body', 'from_mode'].forEach(function (name) {
      var el = form.elements[name];
      if (el) { params.append(name, el.value); }
    });

    // Angehakte bestehende Ticket-Anhaenge
    form.querySelectorAll('input[name="attachment_ids[]"]:checked').forEach(function (cb) {
      params.append('attachment_ids[]', cb.value);
    });

    // Neu ausgewaehlte Uploads: nur die Dateinamen fuer die Anzeige, die Dateien
    // selbst werden erst beim tatsaechlichen Senden hochgeladen.
    var uploadsInput = form.elements['uploads[]'];
    if (uploadsInput && uploadsInput.files) {
      Array.prototype.forEach.call(uploadsInput.files, function (f) {
        params.append('new_upload_names[]', f.name);
      });
    }

    fetch('<%= preview_email_issue_ticket_reply_path(@issue) %>', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/x-www-form-urlencoded',
        'X-CSRF-Token': csrfToken()
      },
      body: params.toString()
    })
      .then(function (r) { return r.text(); })
      .then(function (html) {
        document.getElementById('tr-email-preview-content').innerHTML = html;
        document.getElementById('tr-form-fields').style.display = 'none';
        document.getElementById('tr-form-actions').style.display = 'none';
        document.getElementById('tr-email-preview-panel').style.display = 'block';
      });
  }

  function trBackToEdit() {
    document.getElementById('tr-email-preview-panel').style.display = 'none';
    document.getElementById('tr-form-fields').style.display = '';
    document.getElementById('tr-form-actions').style.display = '';
  }

  function trSendFromPreview() {
    document.getElementById('tr-form').submit();
  }
  //]]>
</script>
