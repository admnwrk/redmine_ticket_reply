<div style="font-family:Arial,Helvetica,sans-serif;font-size:14px;line-height:1.5;color:#222;">
  <% if @body_html.present? %>
    <%= resolved_body_html %>
  <% else %>
    <%= @body.to_s.split("\n").map { |l| ERB::Util.h(l) }.join("<br>\n").html_safe %>
  <% end %>
  <hr style="margin:24px 0 8px;border:none;border-top:1px solid #ccc;">
  <p style="font-size:12px;color:#888;margin:0;">
    <%= ERB::Util.h(@marker) %><br>
    Vorgangsnummer: #<%= @issue.id %><br>
    Bitte antworten Sie oberhalb dieser Linie.
  </p>
</div>
